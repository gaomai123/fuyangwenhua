page {
  background-color: #0a111b !important;
  color: #f7f8fb;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-weight: 400;
  letter-spacing: 0;
  min-height: 100vh;
  overflow-x: hidden;
  width: 100%;
}

.page {
  background:
    linear-gradient(180deg, #0a111b 0, #0a111b calc(env(safe-area-inset-top) + 36rpx), rgba(7, 16, 28, 0.96) calc(env(safe-area-inset-top) + 120rpx)),
    #07101c;
  box-sizing: border-box;
  isolation: isolate;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 68rpx) 22rpx 22rpx;
  position: relative;
  overflow-x: hidden;
  width: 100%;
}

.app-bg {
  background-color: #0a111b;
  bottom: 0;
  height: auto;
  left: 0;
  opacity: 0.9;
  pointer-events: none;
  position: absolute;
  right: 0;
  top: 0;
  width: 100%;
  z-index: 0;
}

.page::before {
  background: linear-gradient(
    180deg,
    #0a111b 0,
    #0a111b calc(env(safe-area-inset-top) + 2rpx),
    rgba(10, 17, 27, 0.78) calc(env(safe-area-inset-top) + 42rpx),
    transparent 100%
  );
  content: "";
  height: calc(env(safe-area-inset-top) + 112rpx);
  left: 0;
  pointer-events: none;
  position: absolute;
  right: 0;
  top: 0;
  z-index: 1;
}

.page > view,
.page > swiper,
.page > form,
.page > button {
  position: relative;
  z-index: 1;
}

.page > .bottom-nav {
  bottom: 0;
  position: fixed;
  z-index: 20;
}

.page > .back-fab {
  position: fixed;
  z-index: 30;
}

.back-fab {
  align-items: center;
  background: rgba(12, 20, 34, 0.72);
  border: 1rpx solid rgba(255, 190, 110, 0.48);
  border-radius: 50%;
  box-shadow: 0 10rpx 26rpx rgba(3, 8, 17, 0.28);
  box-sizing: border-box;
  color: #ffd58b;
  display: flex;
  font-size: 44rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  left: 22rpx;
  line-height: 58rpx;
  position: fixed;
  top: calc(env(safe-area-inset-top) + 66rpx);
  width: 64rpx;
  z-index: 30;
}

.back-fab-hover {
  background: rgba(255, 190, 110, 0.18);
}

.primary-button {
  background: linear-gradient(135deg, #ffd58b, #d98517 54%, #8f4d0d);
  border: 1rpx solid rgba(255, 233, 184, 0.82);
  border-radius: 999rpx;
  box-shadow: 0 0 24rpx rgba(255, 167, 60, 0.42);
  color: #241405;
  font-weight: 800;
  min-height: 76rpx;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.09);
  border: 1rpx solid rgba(255, 190, 110, 0.48);
  border-radius: 999rpx;
  color: #ffd58b;
  min-height: 76rpx;
}

.muted {
  color: rgba(238, 245, 255, 0.65);
}

.empty {
  background: rgba(24, 31, 43, 0.72);
  border: 1rpx solid rgba(255, 179, 80, 0.52);
  border-radius: 22rpx;
  box-shadow: inset 0 0 28rpx rgba(86, 177, 255, 0.1);
  color: rgba(247, 248, 251, 0.72);
  padding: 48rpx 24rpx;
  text-align: center;
}

input,
textarea {
  color: #f8fbff;
}

input::placeholder,
textarea::placeholder {
  color: rgba(238, 245, 255, 0.45);
}

.bottom-space {
  height: calc(88rpx + env(safe-area-inset-bottom));
}

.bottom-nav {
  align-items: center;
  background:
    linear-gradient(180deg, rgba(210, 220, 235, 0.18), rgba(44, 58, 82, 0.46)),
    rgba(8, 14, 25, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-bottom: 0;
  border-radius: 22rpx 22rpx 0 0;
  bottom: 0;
  box-sizing: border-box;
  box-shadow:
    0 -14rpx 38rpx rgba(36, 45, 62, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  color: rgba(255, 255, 255, 0.76);
  display: grid;
  font-size: 19rpx;
  grid-template-columns: repeat(5, 1fr);
  height: calc(82rpx + env(safe-area-inset-bottom));
  justify-items: center;
  left: 20rpx;
  max-width: calc(100vw - 40rpx);
  padding-bottom: env(safe-area-inset-bottom);
  position: fixed;
  right: auto;
  width: calc(100vw - 40rpx);
  z-index: 20;
}

.nav-item,
.nav-brand {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  height: 100%;
  justify-content: center;
  position: relative;
  width: 100%;
}

.nav-badge {
  align-items: center;
  background: #ff4d4f;
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 0 14rpx rgba(255, 77, 79, 0.58);
  box-sizing: border-box;
  color: #fff;
  display: flex;
  font-size: 18rpx;
  font-weight: 800;
  height: 28rpx;
  justify-content: center;
  line-height: 28rpx;
  min-width: 28rpx;
  padding: 0 7rpx;
  position: absolute;
  right: 28rpx;
  top: 8rpx;
  z-index: 2;
}

.nav-icon {
  box-sizing: border-box;
  color: rgba(244, 248, 255, 0.84);
  flex: 0 0 44rpx;
  height: 44rpx;
  position: relative;
  transform: translateZ(0);
  width: 44rpx;
}

.nav-img {
  display: block;
  flex: 0 0 50rpx;
  height: 50rpx;
  width: 50rpx;
}

.nav-item.active,
.nav-brand.active {
  color: #ffc56f;
}

.nav-item.active .nav-icon {
  color: #ffc56f;
  filter: drop-shadow(0 0 10rpx rgba(255, 190, 104, 0.5));
}

.nav-icon-home .home-roof {
  border-left: 5rpx solid currentColor;
  border-top: 5rpx solid currentColor;
  height: 20rpx;
  left: 8rpx;
  position: absolute;
  top: 6rpx;
  transform: rotate(45deg);
  width: 20rpx;
}

.nav-icon-home .home-body {
  border: 5rpx solid currentColor;
  border-radius: 7rpx;
  border-top: 0;
  bottom: 5rpx;
  height: 18rpx;
  left: 9rpx;
  position: absolute;
  width: 24rpx;
}

.nav-icon-play {
  border: 5rpx solid currentColor;
  border-radius: 50%;
}

.nav-icon-play .play-triangle {
  border-bottom: 8rpx solid transparent;
  border-left: 13rpx solid currentColor;
  border-top: 8rpx solid transparent;
  height: 0;
  left: 16rpx;
  position: absolute;
  top: 9rpx;
  width: 0;
}

.nav-icon-message {
  border: 5rpx solid currentColor;
  border-radius: 16rpx;
  height: 36rpx;
  margin-top: 1rpx;
  width: 48rpx;
}

.nav-icon-message::after {
  border-bottom: 5rpx solid currentColor;
  border-right: 5rpx solid currentColor;
  bottom: -9rpx;
  content: "";
  height: 9rpx;
  position: absolute;
  right: 10rpx;
  transform: rotate(35deg);
  width: 9rpx;
}

.message-dot {
  background: currentColor;
  border-radius: 50%;
  height: 5rpx;
  position: absolute;
  top: 13rpx;
  width: 5rpx;
}

.dot-a {
  left: 11rpx;
}

.dot-b {
  left: 21rpx;
}

.dot-c {
  left: 31rpx;
}

.nav-icon-user .user-head {
  border: 5rpx solid currentColor;
  border-radius: 50%;
  height: 15rpx;
  left: 10rpx;
  position: absolute;
  top: 3rpx;
  width: 15rpx;
}

.nav-icon-user .user-body {
  border: 5rpx solid currentColor;
  border-radius: 20rpx 20rpx 8rpx 8rpx;
  border-bottom: 0;
  bottom: 5rpx;
  height: 18rpx;
  left: 4rpx;
  position: absolute;
  width: 34rpx;
}

.nav-brand {
  color: #ffc56f;
  transform: translateY(0);
}

.nav-brand image {
  background:
    radial-gradient(circle at 50% 28%, rgba(255, 213, 139, 0.2), transparent 42%),
    linear-gradient(180deg, rgba(34, 43, 58, 0.92), rgba(91, 98, 112, 0.55));
  border: 2rpx solid rgba(255, 214, 149, 0.58);
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow:
    0 0 34rpx rgba(240, 160, 54, 0.42),
    0 12rpx 28rpx rgba(4, 8, 16, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  height: 74rpx;
  padding: 5rpx;
  width: 74rpx;
}

.nav-brand-label {
  color: #ffd58b;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
  margin-top: 2rpx;
  text-align: center;
}

/* Unified premium theme */
.app-bg {
  opacity: 0.46;
}

.back-fab {
  background: rgba(12, 18, 28, 0.9);
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.24);
  color: rgba(242, 224, 194, 0.9);
}

.primary-button {
  background: linear-gradient(135deg, #e9c27d, #c99348);
  border-color: rgba(255, 224, 168, 0.38);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.24);
  color: #171009;
  font-weight: 700;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.055);
  border-color: rgba(255, 255, 255, 0.12);
  color: rgba(245, 247, 250, 0.86);
}

.empty {
  background: rgba(13, 20, 31, 0.78);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.16);
  color: rgba(221, 228, 238, 0.58);
}

.bottom-nav {
  background: rgba(10, 16, 25, 0.96);
  border-color: rgba(255, 255, 255, 0.09);
  box-shadow: 0 -10rpx 32rpx rgba(0, 0, 0, 0.28);
}

.nav-img {
  height: 44rpx;
  opacity: 0.64;
  width: 44rpx;
}

.nav-item.active .nav-img {
  opacity: 1;
  filter: sepia(0.4) saturate(1.2) drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.28));
}

.nav-brand image {
  background:
    radial-gradient(circle at 50% 28%, rgba(255, 213, 139, 0.2), transparent 42%),
    linear-gradient(180deg, rgba(34, 43, 58, 0.92), rgba(91, 98, 112, 0.55));
  border-color: rgba(255, 214, 149, 0.58);
  box-shadow:
    0 0 24rpx rgba(240, 160, 54, 0.26),
    0 10rpx 22rpx rgba(4, 8, 16, 0.3);
  height: 74rpx;
  padding: 5rpx;
  width: 74rpx;
}

.nav-brand-label {
  color: #e1b56d;
  font-weight: 700;
}

/* Unified typography */
button,
input,
textarea,
picker,
text,
view {
  font-family: "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page-title {
  font-size: 44rpx !important;
  font-weight: 700 !important;
  letter-spacing: 1rpx;
  line-height: 1.24;
  text-shadow: none !important;
}

.section-title {
  font-size: 30rpx !important;
  font-weight: 700 !important;
  letter-spacing: 0;
  line-height: 1.35;
  text-shadow: none !important;
}

.eyebrow,
.hero-kicker,
.promotion-kicker {
  font-size: 19rpx !important;
  font-weight: 600 !important;
  letter-spacing: 2rpx !important;
  line-height: 1.4;
  text-shadow: none !important;
}

.page-desc {
  font-size: 24rpx !important;
  font-weight: 400 !important;
  line-height: 1.6;
}

.entry-title,
.recommend-name,
.notice-title,
.promotion-title,
.news-title {
  font-weight: 700 !important;
  letter-spacing: 0;
  text-shadow: none !important;
}

.entry-desc,
.notice-desc,
.promotion-desc,
.news-summary {
  font-weight: 400 !important;
  line-height: 1.55;
  text-shadow: none !important;
}

.section-more,
.notice-action {
  font-weight: 600 !important;
}

.primary-button,
.ghost-button {
  font-size: 26rpx;
  font-weight: 600 !important;
  letter-spacing: 1rpx;
}

input,
textarea,
picker {
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.55;
}

.bottom-nav,
.nav-brand-label {
  font-weight: 500;
  letter-spacing: 0;
}
