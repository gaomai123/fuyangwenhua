.my-artist-page {
  color: #f8fbff;
  min-height: 100vh;
}

.page-head {
  padding: 28rpx 4rpx 20rpx;
  position: relative;
  z-index: 1;
}

.eyebrow {
  color: rgba(112, 218, 235, 0.84);
  font-size: 20rpx;
  font-weight: 700;
}

.page-title {
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.18;
  margin-top: 8rpx;
}

.page-desc {
  color: rgba(238, 245, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.artist-card {
  background: rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(255, 213, 139, 0.42);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.28);
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.hero {
  align-items: center;
  display: flex;
  gap: 20rpx;
}

.avatar {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 213, 139, 0.42);
  border-radius: 18rpx;
  flex: 0 0 auto;
  height: 150rpx;
  width: 150rpx;
}

.placeholder {
  align-items: center;
  color: #ffd58b;
  display: flex;
  font-size: 54rpx;
  font-weight: 800;
  justify-content: center;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.stage-name {
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.meta {
  color: rgba(238, 245, 255, 0.72);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.status-row text {
  background: rgba(255, 190, 104, 0.14);
  border: 1rpx solid rgba(255, 205, 136, 0.48);
  border-radius: 999rpx;
  color: #ffd58b;
  font-size: 22rpx;
  padding: 8rpx 12rpx;
}

.info-list {
  display: grid;
  gap: 14rpx;
  margin-top: 26rpx;
}

.action-panel {
  align-items: flex-start;
  background: rgba(25, 43, 67, 0.72);
  border: 1rpx solid rgba(93, 221, 232, 0.24);
  border-radius: 12rpx;
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  margin-top: 26rpx;
  padding: 20rpx;
  width: 100%;
}

.action-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.action-desc {
  color: rgba(238, 245, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.status-options {
  box-sizing: border-box;
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
  width: 100%;
}

.status-option {
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.13);
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #f8fbff;
  display: block;
  line-height: 1.4;
  margin: 0;
  max-width: none;
  min-height: 104rpx;
  padding: 20rpx;
  text-align: left;
  width: 100%;
}

.status-option::after {
  border: 0;
}

.status-option.active {
  background: rgba(255, 190, 104, 0.16);
  border-color: rgba(255, 205, 136, 0.62);
}

.status-option[disabled] {
  opacity: 0.72;
}

.option-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.option-desc {
  color: rgba(238, 245, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.latest-request {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  margin-top: 18rpx;
  padding: 20rpx;
}

.section-title {
  color: #ffd58b;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.request-line {
  align-items: center;
  color: rgba(238, 245, 255, 0.84);
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  line-height: 1.5;
  margin-top: 8rpx;
}

.request-line text:first-child {
  color: rgba(238, 245, 255, 0.52);
}

.request-remark {
  color: rgba(238, 245, 255, 0.66);
  font-size: 22rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.info-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 10rpx;
  color: rgba(238, 245, 255, 0.84);
  display: flex;
  font-size: 25rpx;
  justify-content: space-between;
  padding: 18rpx;
}

.info-row text:first-child {
  color: rgba(238, 245, 255, 0.52);
}

.empty {
  position: relative;
  z-index: 1;
}
