.status-request-page {
  color: #f8fbff;
  min-height: 100vh;
}

.page-head {
  padding: 28rpx 4rpx 20rpx;
  position: relative;
  z-index: 1;
}

.eyebrow {
  color: rgba(112, 218, 235, 0.84);
  font-size: 20rpx;
  font-weight: 700;
}

.page-title {
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.18;
  margin-top: 8rpx;
}

.page-desc {
  color: rgba(238, 245, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.form-card {
  background: rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(255, 213, 139, 0.42);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.28);
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.artist-line {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 20rpx;
}

.artist-name {
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.artist-meta {
  color: rgba(238, 245, 255, 0.62);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.field-block {
  margin-top: 28rpx;
}

.field-title {
  color: #ffd58b;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.status-list {
  display: grid;
  gap: 14rpx;
}

.status-option {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.status-option.active {
  background: rgba(102, 224, 236, 0.13);
  border-color: rgba(102, 224, 236, 0.72);
}

.status-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.status-desc {
  color: rgba(238, 245, 255, 0.6);
  font-size: 22rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #66e0ec, #ffd58b);
  border-radius: 12rpx;
  color: #06111d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
  margin: 32rpx 0 0;
}

.submit-btn[disabled] {
  background: rgba(255, 255, 255, 0.14);
  color: rgba(238, 245, 255, 0.5);
}

.empty {
  position: relative;
  z-index: 1;
}
