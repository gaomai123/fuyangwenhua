.detail {
  display: grid;
  gap: 22rpx;
}

.profile-hero,
.section {
  background: rgba(18, 25, 39, 0.76);
  border: 1rpx solid rgba(255, 190, 104, 0.46);
  border-radius: 28rpx;
  box-shadow:
    0 18rpx 42rpx rgba(4, 9, 18, 0.3),
    inset 0 0 30rpx rgba(86, 177, 255, 0.1),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.06);
  overflow: hidden;
}

.profile-hero {
  display: grid;
  grid-template-columns: 45% 55%;
  min-height: 430rpx;
}

.hero-image {
  background: #d9dee8;
  height: 100%;
  min-height: 430rpx;
  width: 100%;
}

.placeholder {
  align-items: center;
  color: #ffb64e;
  display: flex;
  font-size: 82rpx;
  font-weight: 900;
  justify-content: center;
}

.hero-panel {
  background:
    linear-gradient(145deg, rgba(10, 16, 27, 0.76), rgba(25, 36, 56, 0.84)),
    radial-gradient(circle at 80% 12%, rgba(255, 171, 66, 0.18), transparent 34%);
  display: grid;
  gap: 18rpx;
  padding: 30rpx 26rpx;
}

.hero-name-row {
  align-items: center;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
}

.name-wrap {
  align-items: center;
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.name {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.12;
}

.fuyang-badge {
  background: linear-gradient(135deg, rgba(246, 213, 139, 0.22), rgba(201, 141, 47, 0.28));
  border: 1rpx solid rgba(236, 190, 103, 0.66);
  border-radius: 999rpx;
  color: #f4cf8b;
  flex: 0 0 auto;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
  padding: 8rpx 13rpx;
}

.status {
  background: rgba(51, 168, 96, 0.2);
  border: 1rpx solid rgba(110, 238, 148, 0.78);
  border-radius: 999rpx;
  color: #b8f6c4;
  font-size: 23rpx;
  padding: 7rpx 16rpx;
}

.status.closed {
  background: rgba(65, 128, 206, 0.2);
  border-color: rgba(111, 176, 255, 0.78);
  color: #b9d8ff;
}

.meta-row {
  color: rgba(238, 245, 255, 0.82);
  display: flex;
  flex-wrap: wrap;
  font-size: 25rpx;
  gap: 14rpx;
}

.hero-line {
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(238, 245, 255, 0.78);
  display: grid;
  font-size: 24rpx;
  gap: 8rpx;
  padding-top: 14rpx;
}

.hero-line text:first-child {
  color: rgba(238, 245, 255, 0.5);
}

.salary-line text:last-child {
  color: #ffad3f;
  font-size: 31rpx;
  font-weight: 800;
}

.section {
  padding: 24rpx;
}

.section-title {
  color: #f8fbff;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.info-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.info-grid view {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 210, 143, 0.28);
  border-radius: 14rpx;
  display: grid;
  gap: 6rpx;
  padding: 16rpx;
}

.label {
  color: rgba(238, 245, 255, 0.58);
  font-size: 24rpx;
}

.bio {
  color: rgba(238, 245, 255, 0.82);
  font-size: 27rpx;
  line-height: 1.76;
  white-space: pre-wrap;
}

.photo-scroll {
  white-space: nowrap;
}

.photo-scroll image {
  border: 1rpx solid rgba(255, 210, 143, 0.34);
  border-radius: 18rpx;
  display: inline-block;
  height: 220rpx;
  margin-right: 14rpx;
  width: 180rpx;
}

.video-box {
  display: grid;
  gap: 16rpx;
}

.video-player {
  background: #0d1421;
  border: 1rpx solid rgba(107, 189, 255, 0.32);
  border-radius: 18rpx;
  height: 420rpx;
  overflow: hidden;
  width: 100%;
}

.video-box text {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  color: rgba(238, 245, 255, 0.82);
  overflow-wrap: anywhere;
  padding: 16rpx;
}

.video-copy-button {
  font-size: 28rpx;
  margin: 0;
  width: 100%;
}

.booking-bar {
  bottom: calc(102rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  position: fixed;
  right: 24rpx;
  z-index: 24;
}

.booking-bar button {
  font-size: 34rpx;
  min-height: 92rpx;
  width: 100%;
}

.disabled-action {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow: none;
  color: rgba(238, 245, 255, 0.58);
}

.disabled-action[disabled] {
  opacity: 1;
}

.detail-bottom-space {
  height: calc(224rpx + env(safe-area-inset-bottom));
}
