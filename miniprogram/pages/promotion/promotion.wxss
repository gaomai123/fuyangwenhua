.promotion-page {
  color: #f7f8fb;
  display: grid;
  gap: 22rpx;
}

.promotion-head,
.section,
.position-track {
  background: rgba(13, 20, 31, 0.86);
  border: 1rpx solid rgba(226, 181, 109, 0.24);
  border-radius: 18rpx;
  position: relative;
  z-index: 1;
}

.promotion-head {
  padding: 28rpx;
}

.eyebrow {
  color: rgba(226, 181, 109, 0.82);
  font-size: 20rpx;
  font-weight: 700;
}

.title {
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.subtitle {
  color: rgba(238, 245, 255, 0.62);
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.position-track {
  display: grid;
  gap: 12rpx;
  padding: 20rpx;
}

.position-step {
  align-items: center;
  color: rgba(245, 247, 250, 0.82);
  display: flex;
  font-size: 24rpx;
  gap: 14rpx;
}

.step-number {
  align-items: center;
  background: rgba(226, 181, 109, 0.14);
  border: 1rpx solid rgba(226, 181, 109, 0.28);
  border-radius: 50%;
  color: #e4b970;
  display: flex;
  flex: 0 0 auto;
  height: 46rpx;
  justify-content: center;
  width: 46rpx;
}

.promotion-form,
.section {
  display: grid;
  gap: 18rpx;
}

.promotion-form {
  position: relative;
  z-index: 1;
}

.section {
  padding: 22rpx;
}

.section-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

label {
  color: rgba(248, 251, 255, 0.88);
  display: grid;
  font-size: 26rpx;
  gap: 9rpx;
}

input,
textarea,
.picker-box {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.11);
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #f8fbff;
  padding: 18rpx;
}

input,
.picker-box {
  height: 76rpx;
}

.picker-box {
  color: rgba(248, 251, 255, 0.72);
}

textarea {
  min-height: 240rpx;
  width: 100%;
}

.word-count {
  color: rgba(238, 245, 255, 0.42);
  font-size: 20rpx;
  text-align: right;
}

.submit-button {
  margin-top: 4rpx;
}
