.news-detail-page {
  color: #f7f8fb;
  min-height: 100vh;
}

.detail-content {
  display: grid;
  gap: 24rpx;
  padding: 18rpx 0 44rpx;
  position: relative;
  z-index: 1;
}

.article-card,
.media-section {
  background: rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(103, 211, 237, 0.24);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.24);
  padding: 24rpx;
}

.detail-meta {
  align-items: center;
  color: rgba(238, 245, 255, 0.52);
  display: flex;
  font-size: 22rpx;
  gap: 18rpx;
}

.category-pill {
  background: rgba(95, 207, 235, 0.14);
  border: 1rpx solid rgba(95, 207, 235, 0.42);
  border-radius: 999rpx;
  color: #9be9f8;
  padding: 8rpx 14rpx;
}

.detail-title {
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.28;
  margin-top: 20rpx;
}

.cover {
  border: 1rpx solid rgba(103, 211, 237, 0.3);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.3);
  height: 360rpx;
  margin-top: 24rpx;
  width: 100%;
}

.summary {
  background: rgba(255, 190, 104, 0.12);
  border-left: 6rpx solid #ffd58b;
  color: rgba(255, 232, 190, 0.92);
  font-size: 26rpx;
  line-height: 1.65;
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
}

.content {
  color: rgba(238, 245, 255, 0.84);
  font-size: 28rpx;
  line-height: 1.85;
  margin-top: 26rpx;
}

.paragraph + .paragraph {
  margin-top: 22rpx;
}

.section-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.detail-image {
  border-radius: 14rpx;
  display: block;
  height: 320rpx;
  margin-top: 16rpx;
  width: 100%;
}

.video-player {
  border-radius: 14rpx;
  height: 360rpx;
  overflow: hidden;
  width: 100%;
}

.video-link {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  color: rgba(238, 245, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.5;
  padding: 18rpx;
  word-break: break-all;
}

.copy-button {
  font-size: 26rpx;
  margin-top: 16rpx;
}

.empty {
  position: relative;
  z-index: 1;
}
