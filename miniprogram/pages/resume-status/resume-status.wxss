.resume-status-page {
  color: #f8fbff;
  min-height: 100vh;
}

.page-head {
  padding: 28rpx 4rpx 20rpx;
  position: relative;
  z-index: 1;
}

.eyebrow {
  color: rgba(112, 218, 235, 0.84);
  font-size: 20rpx;
  font-weight: 700;
}

.page-title {
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.18;
  margin-top: 8rpx;
}

.page-desc {
  color: rgba(238, 245, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.status-guide {
  background: rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(103, 211, 237, 0.28);
  border-radius: 16rpx;
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  padding: 18rpx;
  position: relative;
  z-index: 1;
}

.guide-step {
  align-items: center;
  color: rgba(238, 245, 255, 0.78);
  display: flex;
  flex-direction: column;
  font-size: 20rpx;
  gap: 8rpx;
  text-align: center;
}

.guide-dot {
  background: #64d7ec;
  border-radius: 50%;
  box-shadow: 0 0 18rpx rgba(100, 215, 236, 0.46);
  height: 14rpx;
  width: 14rpx;
}

.submission-list {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
  position: relative;
  z-index: 1;
}

.submission-card {
  background: rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(103, 211, 237, 0.28);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.28);
  padding: 24rpx;
}

.card-head {
  align-items: flex-start;
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.stage-name {
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
}

.meta {
  color: rgba(238, 245, 255, 0.68);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.status-badge {
  border-radius: 999rpx;
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 800;
  padding: 10rpx 16rpx;
}

.status-new,
.status-pending {
  background: rgba(255, 197, 111, 0.18);
  color: #ffd18a;
}

.status-contacted {
  background: rgba(101, 213, 236, 0.16);
  color: #9be9f8;
}

.status-qualified,
.status-converted,
.status-approved {
  background: rgba(83, 210, 139, 0.18);
  color: #80e6a9;
}

.status-rejected {
  background: rgba(255, 110, 110, 0.18);
  color: #ff9a9a;
}

.info-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr;
  margin-top: 20rpx;
}

.info-grid view {
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 10rpx;
  color: rgba(238, 245, 255, 0.84);
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  padding: 18rpx;
}

.label {
  color: rgba(238, 245, 255, 0.52);
}

.success-box,
.reject-box {
  border-radius: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 16rpx;
  padding: 18rpx;
}

.success-box {
  background: rgba(83, 210, 139, 0.13);
  color: #80e6a9;
}

.reject-box {
  background: rgba(255, 110, 110, 0.12);
  color: #ff9a9a;
}

.empty {
  margin-top: 18rpx;
  position: relative;
  z-index: 1;
}

.submit-button {
  margin-top: 22rpx;
  width: 100%;
}
