.wholesale-page {
  background: #07101c;
  color: #f7f8fb;
  min-height: 100vh;
  overflow-x: hidden;
}


.wholesale-hero {
  background:
    linear-gradient(135deg, rgba(13, 22, 38, 0.84), rgba(50, 58, 72, 0.68)),
    rgba(12, 20, 34, 0.78);
  border: 1rpx solid rgba(255, 205, 136, 0.52);
  border-radius: 18rpx;
  box-shadow: 0 20rpx 44rpx rgba(3, 8, 17, 0.28);
  padding: 34rpx 28rpx;
  position: relative;
  z-index: 1;
}

.hero-kicker {
  color: #67d3ed;
  font-size: 19rpx;
  font-weight: 900;
}

.hero-title {
  color: #fff;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.16;
  margin-top: 12rpx;
}

.hero-desc {
  color: rgba(238, 245, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.6;
  margin-top: 16rpx;
}

.category-scroll {
  margin: 22rpx 0;
  position: relative;
  white-space: nowrap;
  z-index: 1;
}

.category-chip {
  background: rgba(12, 20, 34, 0.72);
  border: 1rpx solid rgba(103, 211, 237, 0.24);
  border-radius: 999rpx;
  color: rgba(238, 245, 255, 0.72);
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 800;
  height: 58rpx;
  line-height: 58rpx;
  margin-right: 12rpx;
  padding: 0 24rpx;
}

.category-chip.active {
  background: rgba(255, 205, 136, 0.18);
  border-color: rgba(255, 205, 136, 0.62);
  color: #ffd58b;
}

.product-list {
  display: grid;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.product-empty {
  display: grid;
  gap: 20rpx;
  justify-items: center;
}

.empty-reset {
  font-size: 24rpx;
  margin: 0;
  min-height: 64rpx;
  padding: 0 28rpx;
}

.product-card {
  background: rgba(12, 20, 34, 0.82);
  border: 1rpx solid rgba(103, 211, 237, 0.26);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 42rpx rgba(3, 8, 17, 0.24);
  display: grid;
  gap: 18rpx;
  grid-template-columns: 204rpx minmax(0, 1fr);
  overflow: hidden;
  padding: 16rpx;
}

.product-cover {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  height: 204rpx;
  width: 204rpx;
}

.product-body {
  min-width: 0;
}

.product-meta-row {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.product-category {
  color: #67d3ed;
  font-size: 21rpx;
  font-weight: 800;
}

.product-brand {
  background: rgba(217, 170, 98, 0.14);
  border: 1rpx solid rgba(217, 170, 98, 0.38);
  border-radius: 999rpx;
  color: #e2b56f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  padding: 7rpx 12rpx;
}

.product-name {
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.32;
  margin-top: 8rpx;
}

.product-summary {
  color: rgba(238, 245, 255, 0.68);
  display: -webkit-box;
  font-size: 23rpx;
  line-height: 1.5;
  margin-top: 10rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-bottom {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
}

.product-price {
  color: #ffd58b;
  font-size: 24rpx;
  font-weight: 900;
}

.product-arrow {
  align-items: center;
  background: rgba(255, 205, 136, 0.16);
  border-radius: 50%;
  color: #ffd58b;
  display: flex;
  font-size: 24rpx;
  font-weight: 900;
  height: 44rpx;
  justify-content: center;
  width: 44rpx;
}

/* Premium visual pass */
.wholesale-hero {
  background: linear-gradient(145deg, rgba(22, 30, 42, 0.96), rgba(11, 17, 27, 0.96));
  border-color: rgba(255, 255, 255, 0.09);
  border-radius: 22rpx;
  box-shadow: 0 20rpx 46rpx rgba(0, 0, 0, 0.25);
}

.hero-kicker {
  color: #d9aa63;
  text-shadow: none;
  letter-spacing: 4rpx;
}

.hero-title {
  color: #f3f4f6;
  font-size: 44rpx;
  font-weight: 700;
  text-shadow: none;
}

.hero-desc {
  color: rgba(226, 232, 240, 0.62);
}

.category-chip {
  color: rgba(229, 233, 240, 0.6);
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.09);
}

.category-chip.active {
  color: #edc784;
  background: rgba(212, 157, 75, 0.12);
  border-color: rgba(221, 174, 98, 0.38);
  box-shadow: none;
}

.product-card {
  background: rgba(15, 23, 35, 0.94);
  border-color: rgba(255, 255, 255, 0.09);
  border-radius: 20rpx;
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.22);
}

.product-cover {
  border-radius: 16rpx;
}

.product-category {
  color: #d9aa63;
  text-shadow: none;
}

.product-name {
  color: #f2f4f7;
  font-weight: 700;
}

.product-summary {
  color: rgba(223, 229, 237, 0.58);
}

.product-price {
  color: #e2b56f;
  font-weight: 700;
  text-shadow: none;
}
