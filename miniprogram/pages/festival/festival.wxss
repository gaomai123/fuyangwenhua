.festival-page {
  background: #dfe5ec;
  color: #17202c;
  min-height: 100vh;
  overflow-x: hidden;
  padding-left: 22rpx;
  padding-right: 22rpx;
}

.festival-shell {
  position: relative;
  z-index: 1;
}

.brand-head {
  align-items: center;
  display: flex;
  justify-content: center;
  padding: 10rpx 0 20rpx;
}

.brand-logo {
  filter: drop-shadow(0 8rpx 16rpx rgba(157, 86, 12, 0.22));
  height: 116rpx;
  width: 330rpx;
}

.hero-card,
.intro-card,
.case-card,
.mode-card,
.contact-card,
.lead-section {
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.58), rgba(205, 214, 225, 0.46)),
    rgba(255, 255, 255, 0.36);
  border: 1rpx solid rgba(255, 214, 151, 0.72);
  border-radius: 18rpx;
  box-shadow:
    0 16rpx 34rpx rgba(48, 58, 75, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  overflow: hidden;
}

.hero-card {
  height: 360rpx;
  position: relative;
}

.hero-slide {
  height: 100%;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.hero-image {
  height: 100%;
  width: 100%;
}

.hero-overlay {
  background: linear-gradient(90deg, rgba(9, 16, 27, 0.86), rgba(9, 16, 27, 0.42), rgba(9, 16, 27, 0.05));
  box-sizing: border-box;
  color: #fff;
  inset: 0;
  padding: 52rpx 42rpx;
  position: absolute;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.22;
  white-space: pre-line;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 24rpx;
}

.hero-mark {
  color: #ffc76d;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 0;
  margin-top: 34rpx;
}

.intro-card,
.section-block,
.contact-card,
.lead-section {
  margin-top: 42rpx;
}

.section-heading {
  align-items: center;
  color: #111827;
  display: flex;
  font-size: 34rpx;
  font-weight: 900;
  gap: 12rpx;
  line-height: 1.2;
  margin-bottom: 20rpx;
}

.heading-mark {
  background: linear-gradient(135deg, #b9610b, #f5b14d);
  border-radius: 4rpx 12rpx 12rpx 4rpx;
  height: 20rpx;
  transform: skewX(-18deg);
  width: 14rpx;
}

.intro-card {
  padding: 24rpx;
}

.intro-content {
  align-items: center;
  display: grid;
  gap: 20rpx;
  grid-template-columns: 1.35fr 0.65fr;
}

.intro-text {
  color: #1f2937;
  font-size: 26rpx;
  line-height: 1.75;
}

.intro-visual {
  align-items: center;
  background:
    radial-gradient(circle at 50% 50%, rgba(245, 177, 77, 0.28), transparent 46%),
    rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  display: flex;
  height: 150rpx;
  justify-content: center;
  position: relative;
}

.music-note {
  color: #d98517;
  font-size: 72rpx;
  font-weight: 900;
  position: relative;
  z-index: 1;
}

.orbit {
  border: 2rpx solid rgba(217, 133, 23, 0.34);
  border-radius: 50%;
  position: absolute;
}

.orbit-a {
  height: 92rpx;
  width: 132rpx;
}

.orbit-b {
  height: 58rpx;
  width: 172rpx;
}

.case-scroll {
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
}

.case-card {
  display: inline-block;
  height: 286rpx;
  margin-right: 18rpx;
  position: relative;
  vertical-align: top;
  white-space: normal;
  width: 214rpx;
}

.case-card:last-child {
  margin-right: 0;
}

.case-card:active {
  transform: scale(0.985);
}

.case-cover {
  height: 138rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.case-image {
  display: block;
  height: 100%;
  width: 100%;
}

.case-play {
  align-items: center;
  background: rgba(12, 20, 34, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  color: #fff;
  display: flex;
  font-size: 26rpx;
  height: 56rpx;
  justify-content: center;
  left: 50%;
  padding-left: 4rpx;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
}

.case-tag {
  background: linear-gradient(135deg, #d98517, #f7c46b);
  border-radius: 0 0 12rpx 0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  left: 0;
  line-height: 40rpx;
  position: absolute;
  text-align: center;
  top: 0;
  width: 42rpx;
}

.case-body {
  box-sizing: border-box;
  height: 148rpx;
  overflow: hidden;
  padding: 14rpx 14rpx 16rpx;
}

.case-title {
  color: #111827;
  display: -webkit-box;
  font-size: 24rpx;
  font-weight: 900;
  height: 62rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 31rpx;
  overflow: hidden;
  word-break: break-all;
}

.case-location {
  color: #4b5563;
  display: -webkit-box;
  font-size: 19rpx;
  height: 50rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 25rpx;
  margin-top: 10rpx;
  overflow: hidden;
  word-break: break-all;
}

.case-desc {
  color: #374151;
  font-size: 21rpx;
  line-height: 1.55;
  margin-top: 10rpx;
}

.case-link {
  color: #b9610b;
  font-size: 22rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.mode-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.mode-card {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 154rpx;
  padding: 16rpx 10rpx;
  text-align: center;
}

.mode-icon {
  align-items: center;
  border: 2rpx solid rgba(217, 133, 23, 0.62);
  border-radius: 16rpx;
  color: #d98517;
  display: flex;
  font-size: 28rpx;
  font-weight: 900;
  height: 54rpx;
  justify-content: center;
  width: 54rpx;
}

.mode-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  margin-top: 14rpx;
}

.mode-desc {
  color: #4b5563;
  font-size: 19rpx;
  line-height: 1.35;
  margin-top: 6rpx;
}

.contact-card {
  padding: 24rpx;
}

.contact-row {
  align-items: stretch;
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1fr;
}

.contact-item {
  background: rgba(255, 255, 255, 0.34);
  border: 1rpx solid rgba(129, 140, 155, 0.24);
  border-radius: 14rpx;
  box-sizing: border-box;
  display: block;
  min-height: 0;
  min-width: 0;
  overflow: hidden;
  padding: 18rpx 20rpx;
  text-align: center;
}

.contact-label {
  color: #4b5563;
  font-size: 23rpx;
  line-height: 1.25;
}

.contact-value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.28;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.contact-divider {
  display: none;
}

.contact-btn {
  background: linear-gradient(135deg, #d98517, #f0b45f);
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #fff;
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  height: 56rpx;
  line-height: 56rpx;
  margin: 16rpx auto 0;
  max-width: 360rpx;
  min-height: 0;
  min-width: 0;
  overflow: hidden;
  padding: 0 18rpx;
  text-align: center;
  width: 100%;
}

.contact-btn::after,
.submit-btn::after {
  border: 0;
}

.lead-section {
  padding: 24rpx;
}

.form-grid {
  display: grid;
  gap: 18rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.field-full {
  grid-column: 1 / -1;
}

.label {
  color: #8a4b12;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.input,
.picker-box,
.textarea {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(129, 140, 155, 0.32);
  border-radius: 10rpx;
  box-sizing: border-box;
  color: #111827;
  font-size: 25rpx;
  width: 100%;
}

.input,
.picker-box {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 18rpx;
}

.textarea {
  height: 168rpx;
  line-height: 1.5;
  padding: 18rpx;
}

.input-placeholder {
  color: rgba(75, 85, 99, 0.48);
  font-size: 24rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #d98517, #f1b75b);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(157, 86, 12, 0.25);
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 24rpx;
}

.bottom-space {
  height: calc(108rpx + env(safe-area-inset-bottom));
}
