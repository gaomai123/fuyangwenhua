.brand-panel {
  background:
    linear-gradient(135deg, rgba(14, 20, 32, 0.9), rgba(34, 46, 66, 0.78)),
    radial-gradient(circle at 74% 24%, rgba(255, 179, 80, 0.16), transparent 36%);
  border: 1rpx solid rgba(255, 190, 104, 0.42);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 38rpx rgba(3, 8, 17, 0.28);
  padding: 34rpx 28rpx;
  text-align: center;
}

.brand-logo-large {
  height: 180rpx;
  width: 280rpx;
}

.brand-title {
  color: #ffc56f;
  font-size: 46rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.brand-desc {
  color: rgba(238, 245, 255, 0.78);
  font-size: 27rpx;
  line-height: 1.8;
  margin-top: 18rpx;
}

.brand-actions {
  box-sizing: border-box;
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 30rpx;
  width: 100%;
}

.brand-actions button {
  box-sizing: border-box;
  font-size: 25rpx;
  line-height: 76rpx;
  margin: 0;
  min-width: 0;
  overflow: hidden;
  padding: 0 12rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}
