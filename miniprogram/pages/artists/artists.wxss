.artists-page {
  background: rgba(5, 10, 20, 0.12);
  color: #f7f8fb;
  min-height: 100vh;
  overflow: hidden;
  position: relative;
}

.artists-page::before {
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  content: "";
  inset: 0;
  opacity: 0.42;
  pointer-events: none;
  position: absolute;
}

.cyber-bg {
  height: 100%;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  position: fixed;
  z-index: 0;
}

.city-line {
  background: linear-gradient(90deg, transparent, rgba(255, 168, 63, 0.42), rgba(88, 202, 255, 0.32), transparent);
  height: 2rpx;
  position: absolute;
  transform-origin: center;
  width: 720rpx;
}

.city-line-a {
  right: -80rpx;
  top: 310rpx;
  transform: rotate(-12deg);
}

.city-line-b {
  left: -140rpx;
  top: 650rpx;
  transform: rotate(15deg);
}

.scan {
  border: 1rpx solid rgba(255, 185, 92, 0.2);
  border-radius: 28rpx;
  position: absolute;
}

.scan-a {
  height: 380rpx;
  right: -70rpx;
  top: 430rpx;
  transform: rotate(7deg);
  width: 360rpx;
}

.scan-b {
  border-color: rgba(98, 180, 255, 0.22);
  bottom: 70rpx;
  height: 300rpx;
  left: -90rpx;
  transform: rotate(-10deg);
  width: 340rpx;
}

.page-head,
.search-box,
.panel-title-row,
.status-tabs,
.filter-panel,
.empty,
.artist-list {
  position: relative;
  z-index: 1;
}

.page-head {
  align-items: center;
  display: flex;
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 26rpx;
  padding-top: 0;
}

.brand-logo {
  filter: drop-shadow(0 0 12rpx rgba(255, 164, 46, 0.45));
  flex: 0 0 auto;
  height: 102rpx;
  width: 176rpx;
}

.eyebrow {
  color: rgba(255, 194, 102, 0.88);
  font-size: 21rpx;
  text-transform: uppercase;
}

.title {
  color: #f8fbff;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.14;
  text-shadow: 0 0 18rpx rgba(255, 162, 56, 0.32);
}

.subtitle {
  color: rgba(244, 249, 255, 0.74);
  font-size: 22rpx;
  line-height: 1.35;
  margin-top: 5rpx;
}

.glass-panel {
  background: rgba(17, 25, 39, 0.72);
  border: 1rpx solid rgba(255, 190, 110, 0.42);
  border-radius: 26rpx;
  box-shadow:
    0 18rpx 42rpx rgba(4, 9, 18, 0.32),
    inset 0 0 28rpx rgba(86, 177, 255, 0.08),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.search-box {
  padding: 18rpx;
}

.search-main {
  align-items: center;
  background: rgba(10, 16, 28, 0.48);
  border: 1rpx solid rgba(255, 184, 92, 0.42);
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  width: 100%;
}

input {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #f8fbff;
  height: 70rpx;
  min-width: 0;
  padding: 0 18rpx;
  width: 100%;
}

.picker-value {
  align-items: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 210, 143, 0.28);
  border-radius: 999rpx;
  box-sizing: border-box;
  box-shadow: inset 0 0 14rpx rgba(255, 255, 255, 0.035);
  color: rgba(248, 251, 255, 0.82);
  display: flex;
  font-size: 18rpx;
  font-weight: 500;
  height: 52rpx;
  justify-content: center;
  letter-spacing: 0;
  line-height: 1;
  overflow: hidden;
  padding: 0 14rpx;
  text-overflow: ellipsis;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.08);
  white-space: nowrap;
  width: 100%;
}

.filter-panel picker {
  flex: 1 1 220rpx;
  min-width: 0;
}

.picker-value.placeholder {
  color: rgba(248, 251, 255, 0.72);
  font-size: 19rpx;
  font-weight: 500;
}

.picker-value:not(.placeholder) {
  background: rgba(255, 183, 88, 0.12);
  border-color: rgba(255, 205, 136, 0.5);
  color: #ffe0ab;
  font-weight: 600;
  text-shadow: 0 0 12rpx rgba(255, 179, 80, 0.22);
}

.search-main input {
  background: transparent;
  border: 0;
  flex: 1;
  min-width: 0;
}

.search-button {
  background: linear-gradient(135deg, #ffd58b, #d98517 54%, #8f4d0d);
  border: 1rpx solid rgba(255, 233, 184, 0.82);
  border-radius: 999rpx;
  box-shadow: 0 0 24rpx rgba(255, 167, 60, 0.42);
  color: #241405;
  box-sizing: border-box;
  display: block;
  flex: 0 0 132rpx;
  font-size: 28rpx;
  font-weight: 800;
  height: 70rpx;
  line-height: 70rpx;
  margin: 0;
  min-height: 0;
  padding: 0;
  width: 132rpx;
}

.search-button::after {
  border: 0;
}

.type-row {
  background: rgba(255, 255, 255, 0.04);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(6, 1fr);
  margin: 18rpx -18rpx -18rpx;
  padding: 16rpx 14rpx;
}

.type-item {
  border: 1rpx solid transparent;
  border-radius: 14rpx;
  color: rgba(239, 245, 255, 0.9);
  font-size: 23rpx;
  min-height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  text-shadow: 0 0 16rpx rgba(109, 191, 255, 0.56);
}

.type-item.active {
  background: rgba(255, 178, 78, 0.16);
  border-color: rgba(255, 190, 110, 0.68);
  box-shadow: 0 0 18rpx rgba(255, 166, 56, 0.22), inset 0 0 18rpx rgba(255, 255, 255, 0.05);
  color: #ffd58b;
  font-weight: 700;
}

.panel-title-row {
  align-items: center;
  display: flex;
  gap: 14rpx;
  margin: 24rpx 8rpx 0;
}

.panel-title-line {
  background: linear-gradient(90deg, #ffac43, rgba(255, 172, 67, 0));
  border-radius: 999rpx;
  height: 4rpx;
  width: 128rpx;
}

.panel-title-text {
  color: rgba(255, 200, 116, 0.8);
  font-size: 18rpx;
  letter-spacing: 3rpx;
}

.status-tabs {
  align-items: flex-end;
  display: flex;
  gap: 52rpx;
  margin: 22rpx 8rpx 18rpx;
}

.status-tab {
  color: rgba(239, 245, 255, 0.48);
  font-size: 36rpx;
  font-weight: 700;
  padding-bottom: 14rpx;
  position: relative;
}

.status-tab.active {
  color: #ffffff;
  text-shadow: 0 0 18rpx rgba(255, 172, 67, 0.5);
}

.status-tab.active::after {
  background: #ffaf3d;
  border-radius: 999rpx;
  bottom: 0;
  box-shadow: 0 0 16rpx rgba(255, 172, 67, 0.8);
  content: "";
  height: 6rpx;
  left: 8rpx;
  position: absolute;
  width: 48rpx;
}

.filter-panel {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 14rpx;
}

.reset-button {
  background: rgba(255, 255, 255, 0.09);
  border: 1rpx solid rgba(255, 190, 110, 0.48);
  color: #ffd58b;
  flex: 0 0 88rpx;
  font-size: 20rpx;
  font-weight: 500;
  height: 48rpx;
  letter-spacing: 0;
  line-height: 48rpx;
  min-height: 0;
  padding: 0;
}

.artist-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.artist-card {
  align-items: stretch;
  background:
    linear-gradient(90deg, rgba(14, 20, 32, 0.88), rgba(24, 34, 52, 0.74)),
    linear-gradient(135deg, rgba(255, 175, 68, 0.12), rgba(91, 174, 255, 0.08));
  border: 1rpx solid rgba(255, 179, 80, 0.58);
  border-radius: 24rpx;
  box-shadow:
    0 0 0 1rpx rgba(255, 255, 255, 0.08),
    0 18rpx 38rpx rgba(0, 0, 0, 0.3),
    inset 0 0 26rpx rgba(66, 171, 255, 0.1);
  color: #f7f7f4;
  display: flex;
  gap: 18rpx;
  overflow: hidden;
  padding: 14rpx;
  position: relative;
}

.artist-card::after {
  background: linear-gradient(180deg, rgba(255, 170, 68, 0.28), transparent 34%, rgba(96, 182, 255, 0.2));
  content: "";
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
}

.avatar {
  background: #d9dee8;
  border-radius: 20rpx;
  box-shadow: 0 0 20rpx rgba(107, 189, 255, 0.26);
  flex: 0 0 auto;
  height: 170rpx;
  width: 194rpx;
}

.placeholder {
  align-items: center;
  color: #ffb64e;
  display: flex;
  font-size: 54rpx;
  font-weight: 900;
  justify-content: center;
}

.artist-info {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0;
}

.artist-title {
  align-items: center;
  display: flex;
  gap: 14rpx;
  justify-content: space-between;
}

.name-wrap {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 10rpx;
  min-width: 0;
}

.name {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fuyang-badge {
  background: linear-gradient(135deg, rgba(246, 213, 139, 0.22), rgba(201, 141, 47, 0.28));
  border: 1rpx solid rgba(236, 190, 103, 0.66);
  border-radius: 999rpx;
  color: #f4cf8b;
  flex: 0 0 auto;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  padding: 7rpx 12rpx;
}

.status {
  align-items: center;
  background: rgba(51, 168, 96, 0.2);
  border: 1rpx solid rgba(110, 238, 148, 0.78);
  border-radius: 999rpx;
  box-shadow: 0 0 16rpx rgba(67, 230, 124, 0.22);
  box-sizing: border-box;
  color: #b8f6c4;
  display: flex;
  flex: 0 0 96rpx;
  font-size: 23rpx;
  height: 42rpx;
  justify-content: center;
  line-height: 1;
  padding: 7rpx 16rpx;
  text-align: center;
  white-space: nowrap;
}

.status.closed {
  background: rgba(65, 128, 206, 0.2);
  border-color: rgba(111, 176, 255, 0.78);
  box-shadow: 0 0 16rpx rgba(111, 176, 255, 0.22);
  color: #b9d8ff;
}

.meta {
  color: rgba(255, 255, 255, 0.84);
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.tag-row text {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 210, 143, 0.4);
  border-radius: 8rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 21rpx;
  padding: 4rpx 10rpx;
}

.dispatch {
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.salary {
  color: #ffad3f;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 8rpx;
  text-shadow: 0 0 14rpx rgba(255, 163, 52, 0.34);
}

/* Premium visual pass */
.cyber-bg,
.artists-page::before {
  display: none;
}

.page-head {
  justify-content: flex-start;
}

.brand-logo {
  width: 148rpx;
  height: 82rpx;
  filter: drop-shadow(0 8rpx 14rpx rgba(0, 0, 0, 0.28));
}

.eyebrow {
  color: #d6aa67;
  text-shadow: none;
  letter-spacing: 4rpx;
}

.title {
  color: #f3f4f6;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-shadow: none;
}

.glass-panel,
.search-main {
  background: rgba(13, 20, 31, 0.84);
  border-color: rgba(255, 255, 255, 0.085);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.2);
}

.search-button {
  background: linear-gradient(135deg, #e4bb76, #c58d42);
  border: 0;
  box-shadow: none;
  color: #171009;
}

.search-button::after {
  display: none;
}

.type-item {
  color: rgba(229, 233, 240, 0.58);
  text-shadow: none;
}

.type-item.active {
  color: #edc784;
  border-color: rgba(221, 174, 98, 0.38);
  background: rgba(212, 157, 75, 0.12);
  box-shadow: none;
}

.panel-title-line {
  background: linear-gradient(90deg, #c9964f, rgba(201, 150, 79, 0));
}

.panel-title-text {
  color: rgba(229, 233, 240, 0.52);
}

.status-tab {
  color: rgba(224, 230, 238, 0.52);
  font-size: 30rpx;
  text-shadow: none;
}

.status-tab.active {
  color: #edc784;
  text-shadow: none;
}

.status-tab.active::after {
  height: 3rpx;
  background: #d5a45b;
  box-shadow: none;
}

.reset-button {
  color: rgba(238, 241, 246, 0.78);
  border-color: rgba(255, 255, 255, 0.1);
}

.artist-card {
  background: linear-gradient(145deg, rgba(21, 29, 41, 0.96), rgba(12, 18, 28, 0.96));
  border-color: rgba(255, 255, 255, 0.09);
  box-shadow: 0 18rpx 38rpx rgba(0, 0, 0, 0.24);
}

.artist-card::after {
  display: none;
}

.avatar {
  border-radius: 14rpx;
  box-shadow: none;
}

.name {
  color: #f2f4f7;
  font-size: 32rpx;
  font-weight: 700;
  text-shadow: none;
}

.fuyang-badge {
  background: rgba(208, 154, 70, 0.16);
  border-color: rgba(224, 179, 109, 0.52);
  color: #e9c57f;
}

.status {
  box-shadow: none;
}

.tag-row text {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(229, 233, 240, 0.62);
}

.salary {
  color: #e0b36d;
  text-shadow: none;
}
